<Project Sdk="Godot.NET.Sdk/4.6.0">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite.Core" Version="8.0.11" />
    <PackageReference Include="SQLitePCLRaw.bundle_winsqlite3" Version="2.1.6" Condition=" '$([MSBuild]::IsOsPlatform(Windows))' == 'true' " />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.6" Condition=" '$([MSBuild]::IsOsPlatform(Windows))' != 'true' " />
  </ItemGroup>
</Project>
